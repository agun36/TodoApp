generator client {
  provider     = "prisma-client-js"
  moduleFormat = "cjs"
}


datasource db {
  provider = "postgresql"
}

model User {
  id               String            @id @default(uuid())
  email            String            @unique
  password         String
  name             String?
  avatarUrl        String?
  statusMessage    String?
  availability     String            @default("available")
  phone            String?
  extension        String?
  department       String?
  designation      String?
  location         String?
  timezone         String?
  bio              String?
  language         String?           @default("en")
  role             String            @default("member")
  activeWorkspaceId String?
  activeWorkspace   Workspace?        @relation("ActiveWorkspace", fields: [activeWorkspaceId], references: [id], onDelete: SetNull)
  todos            Todo[]            @relation("TodoOwner")
  assignedTodos    Todo[]            @relation("TodoAssignee")
  projects         Project[]
  projectMembers   ProjectMember[]
  comments         TaskComment[]
  activities       Activity[]
  invitesSent      Invite[]          @relation("InvitesSent")
  ownedWorkspace   Workspace?        @relation("WorkspaceOwner")
  workspaceMembers WorkspaceMember[]
  groupMembers     GroupMember[]
  groupMessages    GroupMessage[]
  directMessages   DirectMessage[]
  directAsA        DirectConversation[] @relation("DirectParticipantA")
  directAsB        DirectConversation[] @relation("DirectParticipantB")
  meetingsCreated  TeamMeeting[]   @relation("MeetingsCreated")
}

model Workspace {
  id         String            @id @default(uuid())
  name       String
  teamType   String?
  teamSize   String?
  primaryUse String?
  plan                 String            @default("free")
  stripeCustomerId     String?           @unique
  stripeSubscriptionId String?           @unique
  ownerId              String            @unique
  owner      User              @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  activeUsers User[]           @relation("ActiveWorkspace")
  members    WorkspaceMember[]
  invites    Invite[]
  groups     WorkspaceGroup[]
  meetings   TeamMeeting[]
  directConversations DirectConversation[]
  createdAt  DateTime          @default(now())
}

model WorkspaceMember {
  id          String    @id @default(uuid())
  workspaceId String
  userId      String
  role        String    @default("member")
  teamEmail   String?
  joinedAt    DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@unique([workspaceId, teamEmail])
}

model Invite {
  id          String    @id @default(uuid())
  email       String
  token       String    @unique
  workspaceId String
  invitedById String
  invitedBy   User      @relation("InvitesSent", fields: [invitedById], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  acceptedAt  DateTime?
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  groupLinks  GroupInvite[]

  @@unique([workspaceId, email])
}

model WorkspaceGroup {
  id          String        @id @default(uuid())
  workspaceId String
  name        String
  color       String        @default("#6366f1")
  createdAt   DateTime      @default(now())
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  members     GroupMember[]
  inviteLinks GroupInvite[]
  messages    GroupMessage[]

  @@unique([workspaceId, name])
}

model GroupMessage {
  id          String         @id @default(uuid())
  groupId     String
  userId      String
  kind        String         @default("user")
  body        String
  mentions    Json?
  systemEvent Json?
  createdAt   DateTime       @default(now())
  group     WorkspaceGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([groupId, createdAt])
}

model DirectConversation {
  id            String          @id @default(uuid())
  workspaceId   String
  participantA  String
  participantB  String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  workspace     Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  participantAUser User         @relation("DirectParticipantA", fields: [participantA], references: [id], onDelete: Cascade)
  participantBUser User         @relation("DirectParticipantB", fields: [participantB], references: [id], onDelete: Cascade)
  messages      DirectMessage[]

  @@unique([workspaceId, participantA, participantB])
  @@index([workspaceId, updatedAt])
}

model DirectMessage {
  id             String             @id @default(uuid())
  conversationId String
  userId         String
  body           String
  createdAt      DateTime           @default(now())
  conversation   DirectConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model GroupMember {
  id      String         @id @default(uuid())
  groupId String
  userId  String
  group   WorkspaceGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
}

model GroupInvite {
  id       String         @id @default(uuid())
  groupId  String
  inviteId String
  group    WorkspaceGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  invite   Invite         @relation(fields: [inviteId], references: [id], onDelete: Cascade)

  @@unique([groupId, inviteId])
}

model Project {
  id          String          @id @default(uuid())
  name        String
  description String?
  color       String          @default("#4f46e5")
  status      String          @default("active")
  isInbox     Boolean         @default(false)
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  todos       Todo[]
  members     ProjectMember[]
  meetings    TeamMeeting[]
  createdAt   DateTime        @default(now())

  @@unique([userId, name])
}

model TeamMeeting {
  id          String    @id @default(uuid())
  workspaceId String
  projectId   String
  title       String
  description String?
  meetingDays String[]
  meetingTime String?
  createdById String
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy   User      @relation("MeetingsCreated", fields: [createdById], references: [id], onDelete: Cascade)
}

model ProjectMember {
  id        String   @id @default(uuid())
  projectId String
  userId    String
  role      String   @default("member")
  joinedAt  DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

model Todo {
  id          String    @id @default(uuid())
  kind        String    @default("personal")
  title       String
  done        Boolean   @default(false)
  createdAt   DateTime  @default(now())
  dueDate     DateTime?
  repeatType  String?   @default("none")
  repeatOn    String?
  priority    String    @default("medium")
  status      String    @default("todo")
  description String?
  order       Int       @default(0)
  projectId   String?
  project     Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  assigneeId  String?
  assignee    User?     @relation("TodoAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  userId      String
  user        User          @relation("TodoOwner", fields: [userId], references: [id], onDelete: Cascade)
  comments    TaskComment[]
}

model TaskComment {
  id        String   @id @default(uuid())
  todoId    String
  userId    String
  body      String
  todo      Todo     @relation(fields: [todoId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Activity {
  id         String   @id @default(uuid())
  actorId    String
  action     String
  entityType String
  entityId   String
  projectId  String?
  message    String
  metadata   Json?
  createdAt  DateTime @default(now())
  actor      User     @relation(fields: [actorId], references: [id], onDelete: Cascade)
}
