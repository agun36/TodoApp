doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title= title
    style.
      :root {
        --bg: #0f172a; --card: #1e293b; --text: #e2e8f0; --muted: #94a3b8;
        --accent: #3b82f6; --border: #334155; --radius: 12px;
      }
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        background: var(--bg); color: var(--text); min-height: 100vh;
        display: flex; justify-content: center; padding: 40px 20px;
      }
      .container {
        width: 100%; max-width: 650px; background: var(--card); border-radius: var(--radius);
        padding: 32px; box-shadow: 0 20px 40px rgba(0,0,0,0.3);
      }
      h1 { font-size: 28px; margin-bottom: 24px; text-align: center; font-weight: 700; }
      .nav { margin-bottom: 24px; text-align: center; }
      .nav a { color: var(--accent); text-decoration: none; }
      .nav a:hover { text-decoration: underline; }
      .user-item {
        padding: 16px; border: 1px solid var(--border); border-radius: 8px;
        margin-bottom: 12px;
      }
      .user-item .email { font-weight: 600; margin-bottom: 6px; }
      .user-item .id { font-size: 13px; color: var(--muted); word-break: break-all; }
      .empty { text-align: center; color: var(--muted); padding: 24px; }

  body
    .container
      h1 Users
      .nav
        a(href="/todos") ← Back to todos
      if users.length === 0
        .empty No users found.
      else
        each user in users
          .user-item
            .email= user.email
            .id ID: #{user.id}
