# PostgreSQL — use External URL from Render for local dev (host ends with .render.com)
DATABASE_URL=postgresql://user:password@localhost:5432/todoapp

# Auth
SESSION_SECRET=change-me-in-production
JWT_SECRET=change-me-in-production

# Optional: comma-separated emails always promoted to workspace admin on login/signup.
# If unset, the first account in an empty workspace (signup or login) becomes admin.
# ADMIN_EMAILS=you@company.com

# CORS — comma-separated origins for the React app
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Optional: invite + reminder emails (Gmail needs an App Password, not your login password)
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=

# App URLs (invite links open the React app)
APP_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Billing MVP — free plan member cap (owner is not counted)
FREE_MEMBER_LIMIT=3

# Server
PORT=3000
NODE_ENV=development
